[MASTER]
ignore=alembic,migrations,.venv,venv
jobs=4

[MESSAGES CONTROL]
disable=
    C0111,  # missing-docstring
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    W0212,  # protected-access
    C0103,  # invalid-name (for variables)
    R0801,  # duplicate-code

[FORMAT]
max-line-length=100
indent-string='    '

[DESIGN]
max-args=7
max-attributes=10
max-bool-expr=5
max-branches=12
max-locals=15
max-parents=7
max-public-methods=20
max-returns=6
max-statements=50
min-public-methods=0

[BASIC]
good-names=i,j,k,ex,db,_,id

[TYPECHECK]
ignored-modules=sqlalchemy
