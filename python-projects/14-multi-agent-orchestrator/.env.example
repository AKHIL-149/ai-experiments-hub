# ===================================================================
# Multi-Agent Task Orchestrator - Environment Configuration
# ===================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env file to version control!
# ===================================================================

# -------------------------------------------------------------------
# API Server Configuration
# -------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8001
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=multi-agent-orchestrator

# -------------------------------------------------------------------
# Database Configuration
# -------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multi_agent_orchestrator

# Database pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# -------------------------------------------------------------------
# Redis Configuration
# -------------------------------------------------------------------
# Redis connection for caching, pub/sub, and rate limiting
REDIS_URL=redis://localhost:6379/0

# Redis connection pool settings
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# -------------------------------------------------------------------
# LLM Provider Configuration
# -------------------------------------------------------------------
# Primary LLM provider: "openai" or "anthropic"
DEFAULT_LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORGANIZATION=
DEFAULT_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000
TEMPERATURE=0.7

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_MAX_TOKENS=4000
ANTHROPIC_TEMPERATURE=0.7

# Model fallback settings
ENABLE_MODEL_FALLBACK=true
FALLBACK_MODEL=gpt-3.5-turbo

# -------------------------------------------------------------------
# Celery Task Queue Configuration
# -------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# -------------------------------------------------------------------
# Authentication & Security
# -------------------------------------------------------------------
# JWT token settings
SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing
BCRYPT_ROUNDS=12

# CORS settings (JSON array format)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8001"]

# Rate limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# -------------------------------------------------------------------
# Agent Configuration
# -------------------------------------------------------------------
# Maximum concurrent agent executions
MAX_CONCURRENT_AGENTS=10
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT=300

# Agent retry settings
AGENT_MAX_RETRIES=3
AGENT_RETRY_DELAY=5

# Default agent capabilities
ENABLE_WEB_SEARCH=true
ENABLE_CODE_EXECUTION=false
ENABLE_FILE_ACCESS=true
ENABLE_HUMAN_APPROVAL=true

# -------------------------------------------------------------------
# Workflow & Task Configuration
# -------------------------------------------------------------------
# Task orchestration
MAX_PARALLEL_TASKS=5
TASK_RETRY_LIMIT=3
TASK_TIMEOUT=1800

# Workflow settings
MAX_WORKFLOW_DURATION=3600
MAX_WORKFLOW_STEPS=50
WORKFLOW_MAX_RETRIES=3
WORKFLOW_RETRY_DELAY=10

# -------------------------------------------------------------------
# Monitoring & Observability
# -------------------------------------------------------------------
# Enable monitoring features
ENABLE_MONITORING=true
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_DISTRIBUTED_TRACING=true
ENABLE_PERFORMANCE_PROFILING=false

# Metrics export
METRICS_EXPORT_INTERVAL=60
ENABLE_PROMETHEUS_METRICS=false
PROMETHEUS_PORT=9090

# Logging
LOG_FORMAT=json
LOG_FILE_PATH=logs/orchestrator.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# -------------------------------------------------------------------
# Caching Configuration
# -------------------------------------------------------------------
# Enable response caching
ENABLE_CACHING=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Cache key prefix
CACHE_KEY_PREFIX=orchestrator

# -------------------------------------------------------------------
# Circuit Breaker Configuration
# -------------------------------------------------------------------
ENABLE_CIRCUIT_BREAKER=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_EXPECTED_EXCEPTION=Exception

# -------------------------------------------------------------------
# Cost Tracking
# -------------------------------------------------------------------
ENABLE_COST_TRACKING=true
COST_BUDGET_MONTHLY=100.00
COST_ALERT_THRESHOLD=10.0

# Pricing (per 1K tokens)
OPENAI_GPT4_PROMPT_PRICE=0.03
OPENAI_GPT4_COMPLETION_PRICE=0.06
OPENAI_GPT35_PROMPT_PRICE=0.0015
OPENAI_GPT35_COMPLETION_PRICE=0.002
ANTHROPIC_CLAUDE_PROMPT_PRICE=0.015
ANTHROPIC_CLAUDE_COMPLETION_PRICE=0.075

# -------------------------------------------------------------------
# File Storage Configuration
# -------------------------------------------------------------------
UPLOAD_DIR=./data/repos
TEMP_DIR=./data/temp
MAX_UPLOAD_SIZE=104857600

# -------------------------------------------------------------------
# Feature Flags
# -------------------------------------------------------------------
# Enable/disable specific features
ENABLE_AGENT_LEARNING=true
ENABLE_AGENT_REPUTATION=true
ENABLE_COALITION_FORMATION=true
ENABLE_AGENT_NEGOTIATION=true
ENABLE_WEBHOOKS=true
ENABLE_NOTIFICATIONS=true

# -------------------------------------------------------------------
# Data Retention
# -------------------------------------------------------------------
# Data retention periods (days)
TASK_RETENTION_DAYS=90
EXECUTION_RETENTION_DAYS=30
LOG_RETENTION_DAYS=30
AUDIT_RETENTION_DAYS=365

# Auto-cleanup settings
ENABLE_AUTO_CLEANUP=true
CLEANUP_SCHEDULE_CRON=0 2 * * *

# -------------------------------------------------------------------
# Alert Management
# -------------------------------------------------------------------
# Alert channels
ENABLE_EMAIL_ALERTS=false
ENABLE_SLACK_ALERTS=false
ENABLE_WEBHOOK_ALERTS=false

# Email settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@orchestrator.local
ALERT_EMAIL_RECIPIENTS=admin@example.com

# Slack settings
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts

# Alert thresholds
ALERT_FAILED_TASKS_THRESHOLD=5
ALERT_STUCK_TASKS_THRESHOLD=3
ALERT_AGENT_FAILURE_RATE_THRESHOLD=0.1

# -------------------------------------------------------------------
# GraphQL Configuration
# -------------------------------------------------------------------
ENABLE_GRAPHQL=true
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true

# -------------------------------------------------------------------
# WebSocket Configuration
# -------------------------------------------------------------------
ENABLE_WEBSOCKETS=true
WS_HEARTBEAT_INTERVAL=30
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10
WEBSOCKET_MAX_MESSAGE_SIZE=1048576

# -------------------------------------------------------------------
# Development & Testing
# -------------------------------------------------------------------
# Testing settings
TESTING=false
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orchestrator_test

# Development tools
ENABLE_HOT_RELOAD=false
ENABLE_DEBUG_TOOLBAR=false
ENABLE_API_DOCS=true

# -------------------------------------------------------------------
# Production Optimization
# -------------------------------------------------------------------
# Worker settings
UVICORN_WORKERS=4
WORKER_CONNECTIONS=1000

# Timeout settings
REQUEST_TIMEOUT=30
KEEPALIVE_TIMEOUT=5

# Compression
ENABLE_GZIP=true
GZIP_MIN_SIZE=1000

# -------------------------------------------------------------------
# Custom Agent Settings
# -------------------------------------------------------------------
# Research Agent
RESEARCH_AGENT_MAX_SEARCH_RESULTS=10
RESEARCH_AGENT_TIMEOUT=120

# Code Agent
CODE_AGENT_MAX_FILE_SIZE=1048576
CODE_AGENT_ALLOWED_LANGUAGES=python,javascript,typescript,go,rust

# Data Analyst Agent
DATA_ANALYST_MAX_DATASET_SIZE=10485760
DATA_ANALYST_TIMEOUT=300

# Writer Agent
WRITER_AGENT_MAX_OUTPUT_LENGTH=5000
WRITER_AGENT_STYLE=professional

# Planner Agent
PLANNER_AGENT_MAX_STEPS=20
PLANNER_AGENT_OPTIMIZATION_LEVEL=balanced

# -------------------------------------------------------------------
# Environment-Specific Overrides
# -------------------------------------------------------------------
# Set ENVIRONMENT to: development, staging, or production
ENVIRONMENT=development

# ===================================================================
# END OF CONFIGURATION
# ===================================================================
#
# Security Reminders:
# 1. Never commit .env file to version control
# 2. Use strong SECRET_KEY in production
# 3. Change default passwords
# 4. Restrict CORS_ORIGINS in production
# 5. Enable HTTPS in production
# 6. Use environment-specific credentials
# 7. Rotate API keys regularly
# 8. Enable rate limiting in production
# 9. Monitor for security alerts
# 10. Keep dependencies updated
# ===================================================================
