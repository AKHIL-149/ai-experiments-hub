# ============================================================================
# AI Code Review Assistant - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values

# ============================================================================
# Application Settings
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Server host and port
HOST=0.0.0.0
PORT=8000

# ============================================================================
# Database Configuration
# ============================================================================

# Database URL (SQLite default, use PostgreSQL/MySQL for production)
# SQLite: sqlite:///./data/database.db
# PostgreSQL: postgresql://user:password@localhost:5432/dbname
# MySQL: mysql://user:password@localhost:3306/dbname
DATABASE_URL=sqlite:///./data/database.db

# Connection Pool Settings (for PostgreSQL/MySQL only)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================================
# Redis Configuration
# ============================================================================

# Redis URL for caching and Celery
REDIS_URL=redis://localhost:6379/0

# Celery broker URL (usually same as Redis)
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# Logging Configuration
# ============================================================================

# Log format: text or json
# Use 'json' for production log aggregation (ELK, Datadog, etc.)
LOG_FORMAT=text

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Request/Response Logging (middleware)
# Enable detailed HTTP request/response logging for debugging
ENABLE_REQUEST_LOGGING=false

# Log request bodies (WARNING: may log sensitive data like passwords)
LOG_REQUEST_BODY=false

# Log response bodies (WARNING: may log large amounts of data)
LOG_RESPONSE_BODY=false

# ============================================================================
# Security Settings
# ============================================================================

# Session secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=change-me-to-random-string-in-production

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Cookie security (set to true in production with HTTPS)
COOKIE_SECURE=false

# GitHub webhook secret for signature verification
GITHUB_WEBHOOK_SECRET=

# ============================================================================
# Email Configuration (SMTP)
# ============================================================================

# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Email sender details
EMAIL_FROM=noreply@codereview.local
EMAIL_FROM_NAME=Code Review Assistant

# ============================================================================
# Rate Limiting
# ============================================================================

# Rate limit settings configured in middleware

# ============================================================================
# Notes
# ============================================================================
# 1. Never commit .env file with real credentials to version control
# 2. Use strong, random SECRET_KEY in production
# 3. Enable HTTPS and set COOKIE_SECURE=true in production
# 4. Use PostgreSQL or MySQL for production databases
# 5. Configure Redis for production caching and Celery
# 6. Set LOG_FORMAT=json for production log aggregation
# 7. Configure email SMTP for production notifications
# 8. Set ENVIRONMENT=production for production deployments
