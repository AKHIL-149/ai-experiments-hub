# Server Configuration
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Database
DATABASE_URL=sqlite:///./data/database.db
# For PostgreSQL: postgresql://user:password@localhost/code_review_db

# Authentication
SESSION_TTL_DAYS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# GitHub Integration
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Git Configuration
GIT_CLONE_DIR=./data/repos
GIT_TIMEOUT=300

# LLM Providers (Optional - choose one or more)
# Ollama (Local)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# Code Analysis Configuration
MAX_FILE_SIZE_MB=10
ANALYSIS_TIMEOUT_SECONDS=60

# Complexity Analyzer Thresholds
COMPLEXITY_CC_WARN=10
COMPLEXITY_CC_ERROR=15
COMPLEXITY_MI_WARN=20
COMPLEXITY_MI_ERROR=10
COMPLEXITY_COGNITIVE_WARN=15
COMPLEXITY_COGNITIVE_ERROR=25
NESTING_DEPTH_WARN=4
NESTING_DEPTH_ERROR=6

# Analyzer Enable/Disable (comma-separated rule IDs to disable)
DISABLED_RULES=
# Example: DISABLED_RULES=SEC002,SMELL001,COMPLEX003

# Rule Severity Overrides (format: RULE_ID=SEVERITY)
# Valid severities: INFO, WARNING, ERROR, CRITICAL
SEVERITY_OVERRIDE_SEC002=
SEVERITY_OVERRIDE_SEC003=
SEVERITY_OVERRIDE_SEC004=
SEVERITY_OVERRIDE_SEC005=
SEVERITY_OVERRIDE_SEC006=
SEVERITY_OVERRIDE_SEC007=
# Example: SEVERITY_OVERRIDE_SEC002=CRITICAL

# Celery (Async Task Queue)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/app.log

# Feature Flags
ENABLE_AI_ANALYSIS=true
ENABLE_GITHUB_POSTING=false
ENABLE_REFACTORING_SUGGESTIONS=true
